{
  "name": "document-generator",
  "version": "0.1.0",
  "description": "スプレッドシートの案件情報をもとに Google Docs テンプレートへ差し込み、契約書等の PDF を出力する GAS プロジェクト",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "rm -rf dist && tsc -p tsconfig.build.json && cp src/appsscript.json dist/appsscript.json",
    "push": "npm run build && /opt/homebrew/bin/clasp push --force",
    "pull": "/opt/homebrew/bin/clasp pull",
    "open": "/opt/homebrew/bin/clasp open",
    "deploy": "npm run build && /opt/homebrew/bin/clasp deploy",
    "logs": "/opt/homebrew/bin/clasp logs",
    "login": "/opt/homebrew/bin/clasp login"
  },
  "devDependencies": {
    "@google/clasp": "^2.4.2",
    "@types/google-apps-script": "^1.0.83",
    "typescript": "~5.4.5"
  }
}
